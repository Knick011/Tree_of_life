{
  "manifest_version": 3,
  "name": "TOL Scribe EMR Filler",
  "version": "1.3.0",
  "description": "Fills prescription fields in supported EMRs from TOL Scribe clipboard payloads.",
  "permissions": [
    "activeTab",
    "clipboardRead",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://*/*",
    "http://127.0.0.1:4173/*",
    "http://localhost:4173/*"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "TOL Scribe EMR Filler",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "scripts": [
      "background.js"
    ],
    "service_worker": "background.js"
  },
  "commands": {
    "toggle-inline-panel": {
      "suggested_key": {
        "default": "Ctrl+Shift+Y",
        "mac": "Command+Shift+Y"
      },
      "description": "Open the TOL inline fill panel on the current page"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://*/*",
        "http://127.0.0.1:4173/*",
        "http://localhost:4173/*"
      ],
      "exclude_matches": [
        "https://knick011.github.io/Tree_of_life/*"
      ],
      "js": [
        "emr-models.js",
        "recorder.js",
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "tol-scribe-emr-filler@formulaires.local",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    }
  }
}
