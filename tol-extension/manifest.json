{
  "manifest_version": 3,
  "name": "Tree of Life — EMR Rx Filler",
  "version": "1.0.0",
  "description": "Auto-fills prescription fields in OSCAR, PS Suite, and other EMRs from Tree of Life clipboard data.",
  "permissions": ["activeTab", "clipboardRead"],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  }
}
