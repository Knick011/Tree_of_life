{
  "manifest_version": 3,
  "name": "TOL Scribe EMR Filler",
  "version": "1.1.0",
  "description": "Fills prescription fields in supported EMRs from TOL Scribe clipboard payloads.",
  "permissions": [
    "activeTab",
    "clipboardRead",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://*.junoemr.com/juno/oscarRx/*"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "TOL Scribe EMR Filler",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.junoemr.com/juno/oscarRx/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "tol-scribe-emr-filler@formulaires.local",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    }
  }
}
